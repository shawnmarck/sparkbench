#!/usr/bin/env python3
"""Emit live system metrics (JSON) for the Spark portal."""
import json
import os
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from collections import deque
from pathlib import Path

_HISTORY_LEN = 60
_HISTORY = {
    "cpu_util_pct": deque(maxlen=_HISTORY_LEN),
    "gpu_util_pct": deque(maxlen=_HISTORY_LEN),
    "memory_used_pct": deque(maxlen=_HISTORY_LEN),
    "gpu_temp_c": deque(maxlen=_HISTORY_LEN),
    "cpu_temp_c": deque(maxlen=_HISTORY_LEN),
    "gpu_power_w": deque(maxlen=_HISTORY_LEN),
    "net_rx_mbps": deque(maxlen=_HISTORY_LEN),
    "net_tx_mbps": deque(maxlen=_HISTORY_LEN),
}
_PREV_CPU = None
_PREV_CPU_CORES = None
_PREV_NET = None
_SKIP_IFACES = frozenset({"lo"})
_SKIP_IFACE_PREFIXES = ("docker", "br-", "veth", "virbr", "ifb")


def _read_proc_stat():
    cpus = {}
    with open("/proc/stat", encoding="utf-8") as fh:
        for line in fh:
            if not line.startswith("cpu"):
                continue
            parts = line.split()
            name = parts[0]
            fields = [int(x) for x in parts[1:11]]
            while len(fields) < 10:
                fields.append(0)
            cpus[name] = fields
    return cpus


def _cpu_busy(fields):
    user, nice, system, idle, iowait, irq, softirq, steal, guest, guest_nice = fields
    idle_all = idle + iowait
    busy = user + nice + system + irq + softirq + steal + guest + guest_nice
    return busy, busy + idle_all


def _cpu_delta(prev_fields, curr_fields):
    busy_prev, total_prev = _cpu_busy(prev_fields)
    busy_curr, total_curr = _cpu_busy(curr_fields)
    dt = total_curr - total_prev
    if dt <= 0:
        return 0.0
    return round((busy_curr - busy_prev) / dt * 100, 1)


def read_cpu_metrics():
    global _PREV_CPU, _PREV_CPU_CORES
    curr = _read_proc_stat()
    overall = 0.0
    peak_core = 0.0
    core_count = 0

    if _PREV_CPU and "cpu" in curr and "cpu" in _PREV_CPU:
        overall = _cpu_delta(_PREV_CPU["cpu"], curr["cpu"])

    if _PREV_CPU_CORES:
        for name, fields in curr.items():
            if name == "cpu" or not name.startswith("cpu"):
                continue
            if name in _PREV_CPU_CORES:
                core_pct = _cpu_delta(_PREV_CPU_CORES[name], fields)
                peak_core = max(peak_core, core_pct)
                core_count += 1

    _PREV_CPU = {"cpu": curr.get("cpu")}
    _PREV_CPU_CORES = {k: v for k, v in curr.items() if k.startswith("cpu") and k != "cpu"}
    if not core_count:
        core_count = len(_PREV_CPU_CORES)

    return {
        "cpu_util_pct": overall,
        "cpu_peak_core_pct": peak_core,
        "cpu_cores": core_count,
    }


def read_load():
    with open("/proc/loadavg", encoding="utf-8") as fh:
        one, five, fifteen, _ = fh.read().split()[:4]
    return {
        "load_1": round(float(one), 2),
        "load_5": round(float(five), 2),
        "load_15": round(float(fifteen), 2),
    }


def _iface_kind(name: str) -> str | None:
    if name.startswith("wl"):
        return "wifi"
    if name.startswith("eth") or name.startswith("en"):
        return "ethernet"
    return None


def _iface_operstate(name: str) -> str:
    path = Path("/sys/class/net") / name / "operstate"
    try:
        return path.read_text(encoding="utf-8").strip()
    except OSError:
        return "unknown"


def pick_network_iface() -> tuple[str | None, str | None]:
    base = Path("/sys/class/net")
    if not base.is_dir():
        return None, None
    ethernet: list[str] = []
    wifi: list[str] = []
    for entry in sorted(base.iterdir()):
        name = entry.name
        if name in _SKIP_IFACES or name.startswith(_SKIP_IFACE_PREFIXES):
            continue
        kind = _iface_kind(name)
        if not kind or _iface_operstate(name) != "up":
            continue
        if kind == "ethernet":
            ethernet.append(name)
        else:
            wifi.append(name)
    if ethernet:
        return ethernet[0], "ethernet"
    if wifi:
        return wifi[0], "wifi"
    return None, None


def _read_iface_bytes(iface: str) -> tuple[int, int] | None:
    with open("/proc/net/dev", encoding="utf-8") as fh:
        for line in fh:
            if ":" not in line:
                continue
            name, rest = line.split(":", 1)
            if name.strip() != iface:
                continue
            parts = rest.split()
            if len(parts) < 9:
                return None
            return int(parts[0]), int(parts[8])
    return None


def read_network() -> dict:
    global _PREV_NET
    iface, kind = pick_network_iface()
    if not iface:
        return {
            "iface": None,
            "kind": None,
            "label": "offline",
            "rx_mbps": None,
            "tx_mbps": None,
        }

    counters = _read_iface_bytes(iface)
    if not counters:
        return {
            "iface": iface,
            "kind": kind,
            "label": "Wi‑Fi" if kind == "wifi" else "Ethernet",
            "rx_mbps": None,
            "tx_mbps": None,
        }

    rx_bytes, tx_bytes = counters
    now = time.time()
    rx_mbps = None
    tx_mbps = None
    if _PREV_NET and _PREV_NET.get("iface") == iface:
        dt = now - _PREV_NET["at"]
        if dt > 0:
            rx_mbps = round((rx_bytes - _PREV_NET["rx"]) * 8 / dt / 1_000_000, 1)
            tx_mbps = round((tx_bytes - _PREV_NET["tx"]) * 8 / dt / 1_000_000, 1)
            rx_mbps = max(rx_mbps, 0.0)
            tx_mbps = max(tx_mbps, 0.0)

    _PREV_NET = {"iface": iface, "rx": rx_bytes, "tx": tx_bytes, "at": now}
    label = "Wi‑Fi" if kind == "wifi" else "10GbE" if kind == "ethernet" else "Ethernet"
    return {
        "iface": iface,
        "kind": kind,
        "label": label,
        "rx_mbps": rx_mbps,
        "tx_mbps": tx_mbps,
    }


def read_thermals():
    gpu_temp = None
    gpu_power = None
    try:
        out = subprocess.check_output(
            [
                "nvidia-smi",
                "--query-gpu=temperature.gpu,power.draw",
                "--format=csv,noheader,nounits",
            ],
            text=True,
        ).strip()
        temp_s, power_s = [p.strip() for p in out.split(",", 1)]
        gpu_temp = float(temp_s)
        if power_s not in ("", "[N/A]"):
            gpu_power = round(float(power_s), 1)
    except (subprocess.CalledProcessError, ValueError):
        pass

    cpu_temps = []
    base = "/sys/class/thermal"
    if os.path.isdir(base):
        for entry in sorted(os.listdir(base)):
            if not entry.startswith("thermal_zone"):
                continue
            zone = os.path.join(base, entry)
            type_path = os.path.join(zone, "type")
            temp_path = os.path.join(zone, "temp")
            if not os.path.isfile(temp_path):
                continue
            try:
                with open(type_path, encoding="utf-8") as fh:
                    label = fh.read().strip()
                with open(temp_path, encoding="utf-8") as fh:
                    temp_c = int(fh.read().strip()) / 1000.0
                cpu_temps.append({"name": label, "temp_c": round(temp_c, 1)})
            except OSError:
                continue

    cpu_temp = max((t["temp_c"] for t in cpu_temps), default=None)
    return {
        "gpu_temp_c": gpu_temp,
        "gpu_power_w": gpu_power,
        "cpu_temp_c": cpu_temp,
    }


def format_uptime(seconds):
    seconds = int(seconds)
    days, rem = divmod(seconds, 86400)
    hours, rem = divmod(rem, 3600)
    minutes, _ = divmod(rem, 60)
    parts = []
    if days:
        parts.append(f"{days}d")
    if hours or days:
        parts.append(f"{hours}h")
    parts.append(f"{minutes}m")
    return " ".join(parts)


def read_uptime():
    with open("/proc/uptime", encoding="utf-8") as fh:
        uptime_s = float(fh.read().split()[0])
    return {
        "uptime_seconds": int(uptime_s),
        "uptime_human": format_uptime(uptime_s),
    }


_MODEL_SIZE_CACHE = {"at": 0.0, "local_gb": None, "shelf_gb": None}
_MODEL_SIZE_TTL = 120
_INVENTORY_JSON = Path("/opt/spark/portal/models.json")


def _round_gb(nbytes: int) -> float:
    return round(nbytes / (1024**3), 1)


def read_model_footprints() -> tuple[float | None, float | None]:
    now = time.time()
    if now - _MODEL_SIZE_CACHE["at"] < _MODEL_SIZE_TTL:
        return _MODEL_SIZE_CACHE["local_gb"], _MODEL_SIZE_CACHE["shelf_gb"]

    local_gb = None
    shelf_gb = None
    if _INVENTORY_JSON.is_file():
        try:
            payload = json.loads(_INVENTORY_JSON.read_text())
            models = payload.get("models") or []
            local_bytes = sum(
                (m.get("local") or {}).get("size_bytes", 0) for m in models
            )
            shelf_bytes = sum(
                (m.get("shelf") or {}).get("size_bytes", 0) for m in models
            )
            local_gb = _round_gb(local_bytes)
            shelf_gb = _round_gb(shelf_bytes)
        except (OSError, json.JSONDecodeError):
            pass

    _MODEL_SIZE_CACHE.update(
        {"at": now, "local_gb": local_gb, "shelf_gb": shelf_gb}
    )
    return local_gb, shelf_gb


def read_volume_usage(path: str) -> dict | None:
    try:
        usage = shutil.disk_usage(path)
    except OSError:
        return None
    total_gb = _round_gb(usage.total)
    used_gb = _round_gb(usage.used)
    avail_gb = _round_gb(usage.free)
    used_pct = round(usage.used / usage.total * 100, 1) if usage.total else 0.0
    return {
        "total_gb": total_gb,
        "used_gb": used_gb,
        "avail_gb": avail_gb,
        "used_pct": used_pct,
    }


def read_storage():
    local_models_gb, shelf_models_gb = read_model_footprints()
    volumes = []

    spark_usage = read_volume_usage("/")
    volumes.append(
        {
            "label": "Spark SSD",
            "role": "local",
            "models_path": "/models",
            "models_gb": local_models_gb,
            "disk_path": "/",
            "online": spark_usage is not None,
            **(spark_usage or {}),
        }
    )

    nas_mounted = os.path.ismount("/mnt/model-shelf")
    nas_usage = read_volume_usage("/mnt/model-shelf") if nas_mounted else None
    volumes.append(
        {
            "label": "NAS shelf",
            "role": "nas",
            "models_path": "/mnt/model-shelf/models",
            "models_gb": shelf_models_gb if nas_mounted else None,
            "disk_path": "/mnt/model-shelf",
            "online": nas_mounted and nas_usage is not None,
            **(nas_usage or {}),
        }
    )
    return volumes


def read_docker():
    try:
        out = subprocess.check_output(
            [
                "docker",
                "ps",
                "--format",
                "{{.Names}}\t{{.Status}}\t{{.Ports}}",
            ],
            text=True,
            stderr=subprocess.DEVNULL,
        ).strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return []

    containers = []
    for line in out.splitlines():
        if not line.strip():
            continue
        parts = line.split("\t", 2)
        name = parts[0]
        status = parts[1] if len(parts) > 1 else ""
        ports = parts[2] if len(parts) > 2 else ""
        containers.append(
            {
                "name": name,
                "status": status,
                "ports": ports,
                "up": status.lower().startswith("up"),
            }
        )
    return containers


HERMES_CONTAINER = "spark-bot"
HERMES_URL = "http://127.0.0.1:9119/"
HERMES_PROBE_INTERVAL = 20.0
_HERMES_PROBE_AT = 0.0
_HERMES_SERVICE_UP = False


def read_hermes_status(containers):
    """Cached HTTP probe for Hermes dashboard (spark-bot). Container checked every poll."""
    global _HERMES_PROBE_AT, _HERMES_SERVICE_UP
    container_up = any(
        c.get("name") == HERMES_CONTAINER and c.get("up") for c in containers
    )
    if not container_up:
        return {"online": False, "container": False, "service": False}
    now = time.time()
    if now - _HERMES_PROBE_AT >= HERMES_PROBE_INTERVAL:
        _HERMES_PROBE_AT = now
        service_up = False
        try:
            req = urllib.request.Request(
                HERMES_URL,
                headers={"User-Agent": "spark-portal-probe/1"},
            )
            with urllib.request.urlopen(req, timeout=1.0):
                service_up = True
        except urllib.error.HTTPError:
            service_up = True
        except (urllib.error.URLError, OSError, ValueError, TimeoutError):
            service_up = False
        _HERMES_SERVICE_UP = service_up
    return {
        "online": container_up and _HERMES_SERVICE_UP,
        "container": container_up,
        "service": _HERMES_SERVICE_UP,
    }


def probe_openai_models(url, timeout=1.5):
    try:
        req = urllib.request.Request(url, headers={"Accept": "application/json"})
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            payload = json.loads(resp.read().decode())
        models = [m.get("id") for m in payload.get("data", []) if m.get("id")]
        return {
            "up": True,
            "model": models[0] if models else None,
            "models": models,
        }
    except (urllib.error.URLError, TimeoutError, json.JSONDecodeError, OSError):
        return {"up": False, "model": None, "models": []}


def read_inference():
    llama_port = int(os.environ.get("SPARK_LLAMA_PORT", "8081"))
    probes = [
        {"id": "vllm", "label": "vLLM", "port": 8000},
        {"id": "llamacpp", "label": "llama.cpp", "port": llama_port},
    ]
    engines = []
    for probe in probes:
        status = probe_openai_models(f"http://127.0.0.1:{probe['port']}/v1/models")
        engines.append({**probe, **status})
    primary = next((e for e in engines if e["up"]), None)
    return {
        "up": primary is not None,
        "model": primary["model"] if primary else None,
        "engine": primary["id"] if primary else None,
        "engines": engines,
    }


def append_history(metrics):
    for key in _HISTORY:
        if key in metrics and metrics[key] is not None:
            _HISTORY[key].append(metrics[key])
    return {k: list(v) for k, v in _HISTORY.items()}


def read_gpu_util():
    try:
        gpu_out = subprocess.check_output(
            [
                "nvidia-smi",
                "--query-gpu=name,utilization.gpu",
                "--format=csv,noheader,nounits",
            ],
            text=True,
            stderr=subprocess.DEVNULL,
        ).strip()
        name, gpu_util_s = [part.strip() for part in gpu_out.split(",", 1)]
        return name, float(gpu_util_s)
    except (subprocess.CalledProcessError, ValueError, OSError):
        return None, None


def read_metrics():
    gpu_name, gpu_util = read_gpu_util()
    if gpu_util is None:
        gpu_name = gpu_name or "GPU unavailable"
        gpu_util = 0.0

    mem = {}
    with open("/proc/meminfo", encoding="utf-8") as fh:
        for line in fh:
            key, value = line.split(":", 1)
            mem[key.strip()] = int(value.split()[0]) // 1024

    total_mb = mem.get("MemTotal", 0)
    avail_mb = mem.get("MemAvailable", mem.get("MemFree", 0))
    used_mb = max(total_mb - avail_mb, 0)
    used_pct = round((used_mb / total_mb) * 100, 1) if total_mb else 0.0

    metrics = {
        "gpu_name": gpu_name,
        "gpu_util_pct": round(gpu_util, 1),
        "gpu_available": gpu_name != "GPU unavailable",
        "memory_used_mb": used_mb,
        "memory_total_mb": total_mb,
        "memory_used_pct": used_pct,
    }
    metrics.update(read_cpu_metrics())
    metrics.update(read_thermals())
    metrics.update(read_uptime())
    metrics.update(read_load())
    network = read_network()
    metrics["network"] = network
    if network.get("rx_mbps") is not None:
        metrics["net_rx_mbps"] = network["rx_mbps"]
        metrics["net_tx_mbps"] = network["tx_mbps"]
    metrics["storage"] = read_storage()
    metrics["containers"] = read_docker()
    containers = metrics["containers"]
    metrics["hermes"] = read_hermes_status(containers)
    metrics["inference"] = read_inference()
    metrics["history"] = append_history(metrics)
    return metrics


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "--serve":
        from http.server import BaseHTTPRequestHandler, HTTPServer

        class Handler(BaseHTTPRequestHandler):
            def do_GET(self):
                if self.path != "/api/gpu":
                    self.send_error(404)
                    return
                body = json.dumps(read_metrics()).encode()
                self.send_response(200)
                self.send_header("Content-Type", "application/json")
                self.send_header("Cache-Control", "no-store")
                self.end_headers()
                self.wfile.write(body)

            def log_message(self, *_args):
                return

        read_cpu_metrics()
        read_network()
        time.sleep(0.2)
        HTTPServer(("127.0.0.1", 8765), Handler).serve_forever()
        return

    json.dump(read_metrics(), sys.stdout)


if __name__ == "__main__":
    main()