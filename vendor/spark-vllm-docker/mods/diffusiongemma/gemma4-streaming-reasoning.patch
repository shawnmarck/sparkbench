+def _strip_reasoning_start_token(text: str) -> str:
+    """Remove a leading Gemma4 reasoning channel start token."""
+    _, start, reasoning = text.partition(_REASONING_START)
+    if start:
+        return reasoning
+    return text
+
+
+def _strip_disabled_thinking_channel(text: str) -> str:
+    """Treat Gemma4 channel-wrapped text as content when thinking is disabled."""
+    prefix, start, rest = text.partition(_REASONING_START)
+    if not start:
+        return text
+
+    rest = _strip_thought_label(rest)
+    if _REASONING_END in rest:
+        _, _, content = rest.partition(_REASONING_END)
+        return prefix + content
+
+    return prefix + rest
