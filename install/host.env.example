# SparkBench host identity — copy to /etc/spark/host.env (root:root 0644).
# Install scripts and nginx read these via install/common.sh.
# Secrets (SMB passwords) belong in /etc/spark/smb-credentials-models — never here.

SPARK_HOST=sparky
SPARK_LAN_IP=192.168.0.101
SPARK_USER=techno

# Optional NAS shelf (install/spark-install nas)
# NAS_IP=192.168.0.99
