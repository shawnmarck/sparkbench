+def _fmt_kv_dtypes(b: dict[str, Any]) -> str:
+    """Render the KV Dtypes cell, flagging FMHAv2's fp8 dtypes with a footnote.
+
+    FLASHINFER_FMHA_V2 advertises fp8 KV-cache support but dequantizes K/V to
+    BF16 on the fly (no fp8 attention compute), so its fp8 entries carry a `‡`
+    marker explained in a footnote below the table.
+    """
+    if b["name"] != "FLASHINFER_FMHA_V2":
+        return add_literal_quotes(b["kv_cache_dtypes"])
+    items = [item.strip() for item in b["kv_cache_dtypes"].split(",")]
+    cells = [f"`{item}`‡" if item.startswith("fp8") else f"`{item}`" for item in items]
+    return ", ".join(cells)
+
+
+_COL_KV_DTYPES: TableColumn = ("KV Dtypes", _fmt_kv_dtypes)
