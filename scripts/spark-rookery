#!/usr/bin/env bash
# Rookery orchestrator (Phase 4 bake-off)
set -euo pipefail
cmd="${1:-status}"
case "$cmd" in
  status) systemctl is-active spark-rookery.service 2>/dev/null; rookery status 2>/dev/null || true ;;
  logs) journalctl -u spark-rookery.service -f ;;
  restart) sudo systemctl restart spark-rookery.service ;;
  stop) sudo systemctl stop spark-rookery.service ;;
  start) sudo systemctl start spark-rookery.service ;;
  *) echo "Usage: spark-rookery {status|logs|start|stop|restart}"; exit 1 ;;
esac
