+++ b/vllm/entrypoints/openai/chat_completion/serving.py
@@ -72,6 +72,38 @@ if TYPE_CHECKING:
 logger = init_logger(__name__)
 
 
+_GEMMA4_REASONING_START = "<|channel>"
+_GEMMA4_REASONING_END = "<channel|>"
+_GEMMA4_THOUGHT_PREFIX = "thought\n"
+
+
+def _strip_gemma4_content_channels(content: str | None) -> str | None:
+    """Remove Gemma4 thought-channel spans from user-visible content."""
+    if content is None or _GEMMA4_REASONING_START not in content:
+        return content
+
+    result: list[str] = []
+    remaining = content
+    while True:
+        prefix, start, rest = remaining.partition(_GEMMA4_REASONING_START)
+        result.append(prefix)
+        if not start:
+            break
+
+        thought, end, suffix = rest.partition(_GEMMA4_REASONING_END)
+        if not end:
+            # Incomplete channel span. The reasoning parser buffers this path;
+            # the serving-level sanitizer only removes complete spans.
+            result.append(start + rest)
+            break
+
+        if not thought.startswith(_GEMMA4_THOUGHT_PREFIX):
+            result.append(start + thought + end)
+        remaining = suffix
+
+    return "".join(result) or None
+
+
