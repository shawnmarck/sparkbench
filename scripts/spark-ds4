#!/usr/bin/env bash
# DwarfStar (ds4) native DeepSeek V4 Flash server on GB10.
set -euo pipefail

ROOT="${SPARK_ROOT:-/opt/spark}"
BIN="${SPARK_DS4_BIN:-/opt/spark/bin/ds4-server}"
PIN="${SPARK_DS4_PIN:-/opt/spark/data/ds4-dwarfstar.yaml}"
RUN_DIR="${ROOT}/run"
LOG_DIR="${ROOT}/logs"
PID_FILE="${RUN_DIR}/ds4-server.pid"
PROXY_PID_FILE="${RUN_DIR}/ds4-owui-proxy.pid"
PROXY_BIN="${ROOT}/scripts/spark-ds4-owui-proxy.py"
PROXY_PORT="${SPARK_DS4_OWUI_PROXY_PORT:-8002}"
LOCK_FILE="${RUN_DIR}/ds4.lock"
LOG_FILE="${LOG_DIR}/ds4-server.log"
PROXY_LOG_FILE="${LOG_DIR}/ds4-owui-proxy.log"
PORT="${SPARK_DS4_PORT:-8000}"
HOST="${SPARK_DS4_HOST:-0.0.0.0}"
MODEL=""
SERVED_NAME=""
CTX=""
EXTRA_ARGS=()

die() { echo "ERROR: $*" >&2; exit 1; }

load_pin_defaults() {
  [[ -f "${PIN}" ]] || return 0
  eval "$(
    /opt/spark/venv/bin/python - "${PIN}" <<'PY'
import shlex, sys, yaml
pin = yaml.safe_load(open(sys.argv[1])) or {}
model = pin.get("model") or {}
runtime = pin.get("runtime") or {}
print(f"MODEL={shlex.quote(model.get('dest','') + '/' + model.get('gguf_file','') if model.get('dest') and model.get('gguf_file') else '')}")
print(f"SERVED_NAME={shlex.quote(model.get('served_name') or 'deepseek-v4-flash')}")
print(f"PORT={runtime.get('port', 8000)}")
print(f"CTX={runtime.get('default_ctx', 32768)}")
PY
  )"
  # pin dest is directory; build full gguf path
  if [[ -n "${MODEL}" && "${MODEL}" == /models/* ]]; then
    :
  elif [[ -f "${PIN}" ]]; then
    MODEL="$(/opt/spark/venv/bin/python - "${PIN}" <<'PY'
import sys, yaml
from pathlib import Path
pin = yaml.safe_load(open(sys.argv[1])) or {}
m = pin.get("model") or {}
dest = m.get("dest") or ""
gguf = m.get("gguf_file") or ""
p = Path(dest) / gguf if dest and gguf else Path()
print(p if p.is_file() else "")
PY
)"
  fi
}

load_recipe() {
  local recipe="${SPARK_DS4_RECIPE:-}"
  [[ -n "${recipe}" ]] || return 0
  [[ -f "${recipe}" ]] || die "Missing recipe: ${recipe}"
  eval "$(
    /opt/spark/venv/bin/python - "${recipe}" <<'PY'
import shlex, sys, yaml
recipe = yaml.safe_load(open(sys.argv[1])) or {}
print(f"MODEL={shlex.quote(recipe.get('model', ''))}")
print(f"SERVED_NAME={shlex.quote(recipe.get('served_name', ''))}")
print(f"PORT={recipe.get('port', 8000)}")
flat = []
for arg in recipe.get("ds4_args") or []:
    flat.extend(shlex.split(str(arg)))
if flat:
    joined = " ".join(shlex.quote(a) for a in flat)
    print(f"EXTRA_ARGS=({joined})")
else:
    print("EXTRA_ARGS=()")
ctx = None
for i, a in enumerate(flat):
    if a in ("-c", "--ctx") and i + 1 < len(flat):
        ctx = flat[i + 1]
        break
if ctx:
    print(f"CTX={ctx}")
PY
  )"
}

other_engines_running() {
  docker ps --format '{{.Names}}' 2>/dev/null | grep -qx vllm_node && return 0
  [[ -f /opt/spark/run/llama-server.pid ]] && kill -0 "$(cat /opt/spark/run/llama-server.pid)" 2>/dev/null && return 0
  return 1
}

wait_for_exit() {
  local pid="$1" tries=0
  while kill -0 "$pid" 2>/dev/null && (( tries < 60 )); do
    sleep 1; ((++tries)) || true
  done
  kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null || true
}

stop_others() {
  /opt/spark/scripts/spark-eugr down 2>/dev/null || true
  /opt/spark/scripts/spark-llama down 2>/dev/null || true
  if [[ -f "${PID_FILE}" ]]; then
    old="$(cat "${PID_FILE}")"
    kill "${old}" 2>/dev/null || true
    wait_for_exit "$old"
    rm -f "${PID_FILE}"
  fi
  pkill -f "/opt/spark/bin/ds4-server" 2>/dev/null || true
  sleep 1
}

clear_stale_ds4_locks() {
  if ds4_pid_running; then
    return 0
  fi
  rm -f "${LOCK_FILE}" /tmp/ds4.lock 2>/dev/null || true
}

ds4_pid_running() {
  if [[ -f "${PID_FILE}" ]] && kill -0 "$(cat "${PID_FILE}")" 2>/dev/null; then
    return 0
  fi
  pgrep -f "/opt/spark/bin/ds4-server" >/dev/null 2>&1
}

start_owui_proxy() {
  [[ -f "${PROXY_BIN}" ]] || return 0
  if [[ -f "${PROXY_PID_FILE}" ]] && kill -0 "$(cat "${PROXY_PID_FILE}")" 2>/dev/null; then
    return 0
  fi
  nohup /opt/spark/venv/bin/python "${PROXY_BIN}" --serve --port "${PROXY_PORT}" >>"${PROXY_LOG_FILE}" 2>&1 &
  echo $! >"${PROXY_PID_FILE}"
}

stop_owui_proxy() {
  if [[ -f "${PROXY_PID_FILE}" ]]; then
    pid="$(cat "${PROXY_PID_FILE}")"
    kill "${pid}" 2>/dev/null || true
    wait_for_exit "$pid"
    rm -f "${PROXY_PID_FILE}"
  fi
  pkill -f "spark-ds4-owui-proxy.py --serve" 2>/dev/null || true
}



usage() {
  cat <<USAGE
Usage: spark engine ds4 {up|down|status|logs|build}

DwarfStar (ds4) — native DeepSeek V4 Flash (:${PORT}/v1)
Pin: ${PIN}
USAGE
}

cmd="${1:-}"
[[ -n "${cmd}" ]] || { usage; exit 1; }

load_pin_defaults

case "${cmd}" in
  up)
    load_recipe
    [[ -x "${BIN}" ]] || die "Missing ${BIN} — run: sudo bash install/spark-install engine ds4"
    [[ -n "${MODEL}" && -f "${MODEL}" ]] || die "Missing model GGUF (set SPARK_DS4_RECIPE or check ${PIN})"
    stop_others
    mkdir -p "${RUN_DIR}" "${LOG_DIR}"
    clear_stale_ds4_locks
    if ds4_pid_running; then
      die "ds4-server already running (pid $(cat "${PID_FILE}"))"
    fi
    args=( -m "${MODEL}" --host "${HOST}" --port "${PORT}" )
    [[ -n "${CTX}" ]] && args+=( -c "${CTX}" )
    if [[ ${#EXTRA_ARGS[@]} -gt 0 ]]; then
      args+=( "${EXTRA_ARGS[@]}" )
    fi
    nohup env DS4_LOCK_FILE="${LOCK_FILE}" "${BIN}" "${args[@]}" >>"${LOG_FILE}" 2>&1 &
    echo $! >"${PID_FILE}"
    start_owui_proxy
    echo "Started ds4-server pid $(cat "${PID_FILE}") — ${SERVED_NAME:-ds4} on :${PORT}"
    echo "Log: ${LOG_FILE}"
    echo "API: http://sparky:${PORT}/v1"
    echo "Open WebUI chat proxy: http://sparky:${PROXY_PORT}/v1 (thinking off)"
    ;;
  down)
    stop_owui_proxy
    if [[ -f "${PID_FILE}" ]]; then
      pid="$(cat "${PID_FILE}")"
      kill "${pid}" 2>/dev/null || true
      wait_for_exit "$pid"
      rm -f "${PID_FILE}"
      rm -f "${LOCK_FILE}" /tmp/ds4.lock 2>/dev/null || true
      echo "Stopped ds4-server (${pid})"
    else
      pkill -f '/opt/spark/bin/ds4-server' 2>/dev/null && echo "Stopped ds4-server" || echo "Not running"
      rm -f "${LOCK_FILE}" /tmp/ds4.lock 2>/dev/null || true
    fi
    ;;
  status)
    if [[ -f "${PID_FILE}" ]] && kill -0 "$(cat "${PID_FILE}")" 2>/dev/null; then
      echo "Running pid $(cat "${PID_FILE}") — http://127.0.0.1:${PORT}/v1/models"
      curl -sf "http://127.0.0.1:${PORT}/v1/models" | head -c 600 || echo "(API not ready yet)"
      echo
    else
      echo "Not running"
    fi
    ;;
  logs)
    tail -f "${LOG_FILE}"
    ;;
  build)
    VENDOR="${SPARK_DS4_VENDOR:-/opt/spark/vendor/ds4}"
    STAGING_VENDOR="${SPARK_ROOT}/vendor/ds4"
    if [[ ! -d "${VENDOR}/.git" && -d "${STAGING_VENDOR}/.git" ]]; then
      VENDOR="${STAGING_VENDOR}"
    fi
    [[ -d "${VENDOR}" ]] || die "Missing ds4 source — run: sudo bash install/spark-install engine ds4"
    cd "${VENDOR}"
    make cuda-spark -j"$(nproc)"
    mkdir -p /opt/spark/bin
    install -m 755 ./ds4-server ./ds4 ./ds4-bench /opt/spark/bin/
    echo "Installed ds4 binaries to /opt/spark/bin/"
    ;;
  *)
    usage
    exit 1
    ;;
esac
