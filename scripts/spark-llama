#!/usr/bin/env bash
# Start/stop llama.cpp OpenAI-compatible server on GB10.
set -euo pipefail

BIN="/opt/spark/bin/llama-server"
MODEL="${SPARK_LLAMA_MODEL:-/models/unsloth/qwen3.6-35b-a3b/gguf/Qwen3.6-35B-A3B-UD-Q4_K_M.gguf}"
SERVED_NAME="${SPARK_LLAMA_NAME:-qwen3.6-35b-a3b-q4}"
PORT="${SPARK_LLAMA_PORT:-8081}"
RUN_DIR="/opt/spark/run"
LOG_DIR="/opt/spark/logs"
PID_FILE="${RUN_DIR}/llama-server.pid"
LOG_FILE="${LOG_DIR}/llama-server.log"

usage() {
  cat <<EOF
Usage: spark-llama {up|down|status|logs}

GGUF inference via llama-server (Phase 3b).
Default model: ${MODEL}
API: http://sparky:${PORT}/v1

Stop vLLM first: spark-eugr down
EOF
}

die() { echo "ERROR: $*" >&2; exit 1; }

cmd="${1:-}"
[[ -n "${cmd}" ]] || { usage; exit 1; }

case "${cmd}" in
  up)
    [[ -x "${BIN}" ]] || die "Missing ${BIN} — run install/11-llama-cpp-smoke.sh"
    [[ -f "${MODEL}" ]] || die "Missing model: ${MODEL}"
    if docker ps --format '{{.Names}}' 2>/dev/null | grep -qx vllm_node; then
      echo "WARNING: vllm_node is running — stop with: spark-eugr down"
    fi
    mkdir -p "${RUN_DIR}" "${LOG_DIR}"
    if [[ -f "${PID_FILE}" ]] && kill -0 "$(cat "${PID_FILE}")" 2>/dev/null; then
      die "llama-server already running (pid $(cat "${PID_FILE}"))"
    fi
    export GGML_CUDA_ENABLE_UNIFIED_MEMORY="${GGML_CUDA_ENABLE_UNIFIED_MEMORY:-1}"
    nohup "${BIN}" \
      -m "${MODEL}" \
      --alias "${SERVED_NAME}" \
      -ngl 999 \
      -fa 1 \
      --no-mmap \
      -c 32768 \
      --host 0.0.0.0 \
      --port "${PORT}" \
      >>"${LOG_FILE}" 2>&1 &
    echo $! >"${PID_FILE}"
    echo "Started llama-server pid $(cat "${PID_FILE}") — ${SERVED_NAME} on :${PORT}"
    echo "Log: ${LOG_FILE}"
    ;;
  down)
    if [[ -f "${PID_FILE}" ]]; then
      pid="$(cat "${PID_FILE}")"
      kill "${pid}" 2>/dev/null || true
      rm -f "${PID_FILE}"
      echo "Stopped llama-server (${pid})"
    else
      pkill -f '/opt/spark/bin/llama-server' 2>/dev/null && echo "Stopped llama-server" || echo "Not running"
    fi
    ;;
  status)
    if [[ -f "${PID_FILE}" ]] && kill -0 "$(cat "${PID_FILE}")" 2>/dev/null; then
      echo "Running pid $(cat "${PID_FILE}") — http://127.0.0.1:${PORT}/v1/models"
      curl -sf "http://127.0.0.1:${PORT}/v1/models" | head -c 500 || echo "(API not ready yet)"
      echo
    else
      echo "Not running"
    fi
    ;;
  logs)
    tail -f "${LOG_FILE}"
    ;;
  *)
    usage
    exit 1
    ;;
esac
