#!/usr/bin/env bash
# Thin wrapper for Rookery systemd service (experimental — see docs/BAKE-OFF.md).
set -euo pipefail
cmd="${1:-status}"
case "$cmd" in
  status)
    systemctl is-active rookery.service 2>/dev/null || echo "rookery: inactive"
    curl -sf --max-time 2 "http://127.0.0.1:3131/" >/dev/null && echo "UI: ok" || echo "UI: waiting"
    ;;
  logs) journalctl -u rookery.service -f ;;
  start) sudo systemctl start rookery.service ;;
  stop) sudo systemctl stop rookery.service ;;
  restart) sudo systemctl restart rookery.service ;;
  *) echo "Usage: spark-rookery {status|logs|start|stop|restart}"; exit 1 ;;
esac